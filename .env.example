# LLM VRAM Calculator Environment Variables
# Copy this file to .env.local for local development

# Vercel Analytics (optional)
# Enable analytics for the deployed version
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=

# Site URL (optional, defaults to current domain)
# Used for generating share URLs
NEXT_PUBLIC_SITE_URL=https://llm-vram-calculator.vercel.app

# Google Analytics (optional)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
